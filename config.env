# DATA 789 · HW4 deploy layer — shared settings the scripts read.
# Values are CONFIRMED against the golden Project 2 image (FastAPI on 8000, /health, /predict).

# IMAGE — the published, pre-built fraud API image students PULL. Build it from your
# golden-reference SOLUTION branch (where /predict is implemented), push to a public
# registry, and put the path here. See INSTRUCTOR-SETUP.md.
IMAGE="ghcr.io/rfsalas/trustbank-fraud:v1"     # ← change if you published elsewhere

# Port the API listens on (Dockerfile: EXPOSE 8000 / uvicorn --port 8000)
CONTAINER_PORT="8000"

# Endpoints (from src/api/main.py)
PREDICT_PATH="/predict"
HEALTH_PATH="/health"

# Region for the Azure Container Apps deploy (deploy_azure.sh). eastus2 is allowed by the
# Azure for Students region policy; centralus is DISALLOWED there. Override with: export LOCATION=<region>
# Allowed set (Azure for Students): eastus2 westus3 northcentralus southcentralus canadacentral
LOCATION="eastus2"

# The API reads customer features from Redis when scoring /predict.
# k8s/redis.yaml deploys Redis behind a Service named "redis"; the API finds it here.
REDIS_HOST="redis"
